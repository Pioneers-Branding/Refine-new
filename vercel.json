{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.6.2",
      "excludeFiles": "{assets/**,.git/**}"
    }
  },
  "routes": [
    {
      "src": "/laser-hair-removal-in-uganda-kampala-juba",
      "status": 301,
      "headers": { "Location": "/laser-hair-removal" }
    },
    {
      "src": "/weight-loss-kampala-juba",
      "status": 301,
      "headers": { "Location": "/semaglutide-ozempic-weight-loss" }
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
