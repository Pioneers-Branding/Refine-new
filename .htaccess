DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Handle 301 Redirects
    RewriteRule ^laser-hair-removal-in-uganda-kampala-juba$ /laser-hair-removal [R=301,L]
    RewriteRule ^weight-loss-kampala-juba$ /semaglutide-ozempic-weight-loss [R=301,L]

    # Explicit routing for blog main page and blog articles FIRST (prevents redirect loops)
    RewriteRule ^blog/?$ blog.php [QSA,L]
    RewriteRule ^blog/(.+)$ blog.php?slug=$1 [QSA,L]

    # Redirect trailing slashes to non-trailing slashes (except directories and blog)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/blog
    RewriteRule ^(.*)/$ /$1 [R=301,L]

    # Route clean URLs to .php files if file exists
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^([^\.]+)$ $1.php [NC,L]
</IfModule>
